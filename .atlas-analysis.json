  "keyFeatures": [
    "On-premises document verification with full data sovereignty",
    "Multi-pass OCR extraction with confidence scoring per field",
    "Automated fraud detection (ELA, geometry checks, recapture spoofing)",
    "Real-time capture quality analysis before submission",
    "Compliance officer dashboard with risk scoring and status workflows",
    "Manual audit portal with side-by-side document and OCR comparison",
    "Webhook callbacks for async verification completion",
    "Python SDK for programmatic integration",
    "AI-generated natural language explanation of flagged documents",
    "Biometric selfie audit with facial similarity scoring"
  ],
  "publicApiSurface": [
    "POST /api/verifications",
    "GET /api/verifications",
    "GET /api/verifications/:id",
    "PATCH /api/verifications/:id/status",
    "GET /api/verifications/:id/explain",
    "POST /api/verifications/check-quality",
    "GET /api/audit-logs",
    "GET /api/stats/ocr-node",
    "QuickKYCClient.check_quality(image)",
    "QuickKYCClient.create_verification(document_front, webhook_url)",
    "QuickKYCClient.update_verification_status(verification_id, status, notes)",
    "QuickKYCError / ValidationError / NotFoundError / ServerError"
  ]
